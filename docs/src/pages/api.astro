---
import RetroLayout from '../layouts/RetroLayout.astro'
---

<RetroLayout title="PixDock — API Reference" activePage="api" description="Complete REST API and WebSocket reference for PixDock.">

  <section style="padding: 50px 0;">
    <div class="container">

      <h1 class="section-title section-title--pink" style="font-size: 20px;">
        <span class="dim">// </span>API REFERENCE
      </h1>

      <p class="text-center mb-5" style="color: var(--text-dim); max-width: 650px; margin-left: auto; margin-right: auto;">
        Every endpoint documented in the style of a 1997 web API manual that was printed on dot-matrix paper
        and stapled together by an intern named Kevin.
      </p>

      <hr class="rainbow-hr">

      <!-- BASE URL -->
      <div class="bevel-panel mb-4">
        <h2 style="font-family: var(--font-pixel); font-size: 10px; color: var(--neon-green); margin-bottom: 12px;">
          ▸ BASE URL
        </h2>
        <div class="code-block" data-lang="http">http://localhost:8420</div>
        <p style="color: var(--text-dim); line-height: 1.8; margin-top: 12px; font-size: 13px;">
          Replace <code style="color: var(--neon-cyan);">localhost</code> with your server's IP and
          <code style="color: var(--neon-cyan);">8420</code> with your custom port if changed.
        </p>
      </div>

      <!-- AUTH -->
      <div class="bevel-panel mb-4">
        <h2 style="font-family: var(--font-pixel); font-size: 10px; color: var(--neon-yellow); margin-bottom: 12px;">
          🔐 AUTHENTICATION
        </h2>
        <p style="color: var(--text); line-height: 1.8; margin-bottom: 12px;">
          If <code style="color: var(--neon-yellow);">PIXDOCK_TOKEN</code> is set, all endpoints except
          <code style="color: var(--neon-green);">/api/health</code> require authentication.
        </p>
        <div class="code-block" data-lang="http" style="margin-bottom: 10px;">
<span class="comment"># REST — send as header</span>
<span class="keyword">Authorization:</span> <span class="string">Bearer your-token-here</span></div>
        <div class="code-block" data-lang="http">
<span class="comment"># WebSocket — send as query param</span>
<span class="keyword">ws://</span>localhost:8420<span class="keyword">/ws</span><span class="string">?token=your-token-here</span></div>
      </div>

      <hr class="rainbow-hr rainbow-hr--thin">

      <!-- ENDPOINTS TABLE -->
      <h2 style="font-family: var(--font-pixel); font-size: 12px; color: var(--neon-cyan); margin-bottom: 20px; text-align: center;">
        ENDPOINT OVERVIEW
      </h2>
      <div style="overflow-x: auto;" class="mb-4">
        <table class="retro-table">
          <thead>
            <tr><th>Method</th><th>Path</th><th>Auth</th><th>Description</th></tr>
          </thead>
          <tbody>
            <tr><td><span class="neon-purple">GET</span></td><td><code class="neon-green">/ws</code></td><td>Token (query)</td><td>WebSocket — DashboardState broadcast</td></tr>
            <tr><td><span class="neon-green">GET</span></td><td><code class="neon-green">/api/health</code></td><td><span class="neon-green">No</span></td><td>Health check — always public</td></tr>
            <tr><td><span class="neon-green">GET</span></td><td><code class="neon-green">/api/nodes</code></td><td>Yes</td><td>Swarm nodes list</td></tr>
            <tr><td><span class="neon-green">GET</span></td><td><code class="neon-green">/api/services</code></td><td>Yes</td><td>Swarm services with replica counts</td></tr>
            <tr><td><span class="neon-green">GET</span></td><td><code class="neon-green">/api/containers</code></td><td>Yes</td><td>All containers</td></tr>
            <tr><td><span class="neon-green">GET</span></td><td><code class="neon-green">/api/services/:id/tasks</code></td><td>Yes</td><td>Tasks for a specific service</td></tr>
            <tr><td><span class="neon-yellow">POST</span></td><td><code class="neon-green">/api/services/:id/scale</code></td><td>Yes</td><td>Scale service <code>&#123;"replicas": N&#125;</code></td></tr>
            <tr><td><span class="neon-yellow">POST</span></td><td><code class="neon-green">/api/containers/:id/action</code></td><td>Yes</td><td>Start / stop / restart container</td></tr>
            <tr><td><span class="neon-green">GET</span></td><td><code class="neon-green">/api/containers/:id/logs</code></td><td>Yes</td><td>Container log output</td></tr>
          </tbody>
        </table>
      </div>

      <hr class="rainbow-hr rainbow-hr--thin">

      <!-- WebSocket Detail -->
      <div class="neon-box neon-box--pink mb-4">
        <h3 style="font-family: var(--font-pixel); font-size: 10px; color: var(--neon-pink); margin-bottom: 12px;">
          GET /ws — WebSocket Broadcast
        </h3>
        <p style="color: var(--text); line-height: 1.8; margin-bottom: 12px;">
          Upgrades to WebSocket and broadcasts <code style="color: var(--neon-cyan);">DashboardState</code>
          JSON every 3 seconds. Contains containers, services (Swarm), nodes (Swarm), and Docker info.
        </p>
        <div class="code-block" data-lang="javascript">
<span class="keyword">const</span> ws = <span class="keyword">new</span> WebSocket(<span class="string">'ws://localhost:8420/ws?token=my-token'</span>);
ws.onmessage = (e) =&gt; {'{'}
  <span class="keyword">const</span> state = JSON.parse(e.data);
  console.log(state.mode);  <span class="comment">// "swarm" or "standalone"</span>
{'}'};</div>
      </div>

      <!-- Container Action Detail -->
      <div class="neon-box mb-4">
        <h3 style="font-family: var(--font-pixel); font-size: 10px; color: var(--neon-green); margin-bottom: 12px;">
          POST /api/containers/:id/action
        </h3>
        <p style="color: var(--text); line-height: 1.8; margin-bottom: 12px;">
          Control a container. The <code style="color: var(--neon-cyan);">:id</code> is validated against
          <code style="color: var(--neon-yellow);">[a-zA-Z0-9_.-]&#123;1,128&#125;</code>.
        </p>
        <div class="code-block" data-lang="bash">
<span class="keyword">curl</span> <span class="flag">-X</span> POST localhost:8420/api/containers/my-app/action \
  <span class="flag">-H</span> <span class="string">"Authorization: Bearer token"</span> \
  <span class="flag">-d</span> <span class="string">'{'{'}&quot;action&quot;: &quot;restart&quot;{'}'}'</span></div>
        <table class="retro-table mt-3">
          <thead><tr><th>Action</th><th>Effect</th></tr></thead>
          <tbody>
            <tr><td><code class="neon-green">start</code></td><td>Starts a stopped container</td></tr>
            <tr><td><code class="neon-yellow">stop</code></td><td>Gracefully stops a running container</td></tr>
            <tr><td><code class="neon-pink">restart</code></td><td>Stops then starts a container</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Logs Detail -->
      <div class="bevel-panel mb-4">
        <h3 style="font-family: var(--font-pixel); font-size: 10px; color: var(--neon-purple); margin-bottom: 12px;">
          GET /api/containers/:id/logs
        </h3>
        <p style="color: var(--text); line-height: 1.8; margin-bottom: 12px;">
          Fetch the last N lines of container log output. Returns plain text.
        </p>
        <div class="code-block" data-lang="bash">
<span class="keyword">curl</span> localhost:8420/api/containers/my-app/logs<span class="string">?tail=100&amp;timestamps=true</span> \
  <span class="flag">-H</span> <span class="string">"Authorization: Bearer token"</span></div>
        <table class="retro-table mt-3">
          <thead><tr><th>Param</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
          <tbody>
            <tr><td><code class="neon-cyan">tail</code></td><td>integer</td><td>200</td><td>Lines from end</td></tr>
            <tr><td><code class="neon-cyan">timestamps</code></td><td>boolean</td><td>false</td><td>Prepend timestamps</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Error Responses -->
      <div class="bevel-panel mb-4">
        <h2 style="font-family: var(--font-pixel); font-size: 10px; color: var(--neon-red); margin-bottom: 12px;">
          ⚠ ERROR RESPONSES
        </h2>
        <p style="color: var(--text); line-height: 1.8; margin-bottom: 12px;">
          All errors return structured JSON. No stack traces, no info leakage.
        </p>
        <div class="code-block" data-lang="json">
{'{'} <span class="string">&quot;error&quot;</span>: <span class="string">&quot;invalid_action&quot;</span>, <span class="string">&quot;message&quot;</span>: <span class="string">&quot;Must be: start, stop, restart&quot;</span> {'}'}</div>
        <table class="retro-table mt-3">
          <thead><tr><th>Code</th><th>Meaning</th></tr></thead>
          <tbody>
            <tr><td><span class="neon-green">200</span></td><td>Success</td></tr>
            <tr><td><span class="neon-yellow">400</span></td><td>Bad request</td></tr>
            <tr><td><span class="neon-red">401</span></td><td>Unauthorized</td></tr>
            <tr><td><span class="neon-red">404</span></td><td>Not found</td></tr>
            <tr><td><span class="neon-red">500</span></td><td>Server error</td></tr>
          </tbody>
        </table>
      </div>

    </div>
  </section>

</RetroLayout>
