---
// Decorative MIDI player — purely visual
---

<div class="midi-player">
  <span class="midi-player__icon">♫</span>
  <div class="midi-player__info">
    <div class="midi-player__title">NOW PLAYING</div>
    <div class="midi-player__track">pixdock_theme.mid</div>
  </div>
  <div class="midi-player__bars">
    <div class="midi-player__bar" style="height: 12px; animation-delay: 0s;"></div>
    <div class="midi-player__bar" style="height: 18px; animation-delay: 0.1s;"></div>
    <div class="midi-player__bar" style="height: 8px; animation-delay: 0.2s;"></div>
    <div class="midi-player__bar" style="height: 16px; animation-delay: 0.15s;"></div>
    <div class="midi-player__bar" style="height: 10px; animation-delay: 0.05s;"></div>
    <div class="midi-player__bar" style="height: 20px; animation-delay: 0.25s;"></div>
    <div class="midi-player__bar" style="height: 6px; animation-delay: 0.12s;"></div>
  </div>
</div>
